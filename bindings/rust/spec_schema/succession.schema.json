{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://causalontology.org/schema/succession.schema.json",
  "title": "Succession",
  "type": "object",
  "required": [
    "id",
    "predecessor",
    "successor",
    "timestamp"
  ],
  "additionalProperties": false,
  "properties": {
    "id": {
      "type": "string",
      "pattern": "^succession:[0-9a-f]{64}$"
    },
    "type": {
      "const": "succession"
    },
    "predecessor": {
      "type": "string",
      "pattern": "^ed25519:[0-9a-f]{64}$"
    },
    "successor": {
      "type": "string",
      "pattern": "^ed25519:[0-9a-f]{64}$"
    },
    "timestamp": {
      "type": "string",
      "format": "date-time"
    },
    "signature": {
      "type": "string",
      "pattern": "^[0-9a-f]{128}$",
      "description": "signed by the PREDECESSOR key"
    }
  }
}

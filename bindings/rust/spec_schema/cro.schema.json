{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://causalontology.org/schema/cro.schema.json",
  "title": "Causal Relation Object",
  "type": "object",
  "required": [
    "id",
    "causes",
    "effects"
  ],
  "additionalProperties": false,
  "properties": {
    "id": {
      "$ref": "#/$defs/croId"
    },
    "type": {
      "const": "cro"
    },
    "causes": {
      "type": "array",
      "minItems": 1,
      "items": {
        "$ref": "#/$defs/occId"
      }
    },
    "effects": {
      "type": "array",
      "minItems": 1,
      "items": {
        "$ref": "#/$defs/occId"
      }
    },
    "mechanism": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/croId"
      },
      "description": "identifiers of finer Causal Relation Objects whose composition realizes this one (hierarchical decomposition; must be acyclic; consistency per semantics.md rule 7)"
    },
    "temporal": {
      "$ref": "#/$defs/temporalWindow"
    },
    "modality": {
      "enum": [
        "necessary",
        "sufficient",
        "contributory",
        "preventive"
      ]
    },
    "context": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/occId"
      },
      "description": "enabling conditions under which the relation holds"
    },
    "refines": {
      "$ref": "#/$defs/croId",
      "description": "the more partial Causal Relation Object this one enriches (lineage; acyclic; must preserve the parent's specified fields)"
    }
  },
  "$defs": {
    "croId": {
      "type": "string",
      "pattern": "^cro:[0-9a-f]{64}$"
    },
    "occId": {
      "type": "string",
      "pattern": "^occ:[0-9a-f]{64}$"
    },
    "temporalWindow": {
      "type": "object",
      "required": [
        "dmin",
        "dmax",
        "unit"
      ],
      "additionalProperties": false,
      "properties": {
        "dmin": {
          "type": "number",
          "minimum": 0
        },
        "dmax": {
          "type": "number",
          "minimum": 0
        },
        "unit": {
          "enum": [
            "instant",
            "seconds",
            "minutes",
            "hours",
            "days",
            "weeks",
            "months",
            "years"
          ]
        }
      }
    }
  }
}

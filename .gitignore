# Editor / OS cruft
.DS_Store
Thumbs.db
*.swp
*~
*.bak
*.orig
*.rej
.idea/
.vscode/

# Logs
*.log

# Local agent instructions (keep local-only, never commit)
CLAUDE.md

# Secrets (never commit)
.env
.envrc
*.pem
*.key

# Persistent Tier A node database (never commit a real store)
/store/server/data/
*.db
*.db-wal
*.db-shm

# Signed snapshot dumps (Phase two): never commit a real multi-megabyte dump,
# but DO keep the small committed example under dumps/example/ for the tests.
/dumps/*
!/dumps/example/
# Private signing seeds for the genesis node (never commit)
*.seed

# Python
*.pyc
*.pyo
__pycache__/
/bindings/python/dist/
/bindings/python/build/
/bindings/python/*.egg-info/
/bindings/python/.pytest_cache/

# JavaScript
node_modules/
/bindings/javascript/*.tgz

# Rust
/bindings/rust/target/

# Swift
/bindings/swift/.build/
/bindings/swift/Package.resolved

# Go
/bindings/go/go.sum

# Dart
/bindings/dart/.dart_tool/
/bindings/dart/pubspec.lock

# C# / .NET
/bindings/**/obj/
/bindings/**/bin/Debug/
/bindings/**/bin/Release/
*.nupkg
*.snupkg

# Java (Maven)
/bindings/java/out/
/bindings/java/target/
/bindings/kotlin/*.jar

# Kotlin / Native
/bindings/kotlin/build/
/bindings/kotlin/.gradle/

# Haskell
/bindings/haskell/dist-newstyle/
/bindings/haskell/.stack-work/

# Perl (ExtUtils::MakeMaker build outputs)
/bindings/perl/Makefile
/bindings/perl/MYMETA.*
/bindings/perl/MANIFEST
/bindings/perl/blib/
/bindings/perl/pm_to_blib
/bindings/perl/*.tar.gz

# Elixir
/bindings/elixir/_build/
/bindings/elixir/deps/
/bindings/elixir/*.tar

# Ruby
/bindings/ruby/*.gem

# Zig
/.zig-cache/
/zig-out/
/bindings/zig/.zig-cache/
/bindings/zig/zig-out/

# Generic per-binding build dir catch-all
/.build/
/bindings/**/.build/

# Editor / OS cruft
.DS_Store
Thumbs.db
*.swp
*~
*.bak
*.orig
*.rej
.idea/
.vscode/

# Logs
*.log

# Secrets (never commit)
.env
.envrc
*.pem
*.key

# Python
*.pyc
*.pyo
__pycache__/
/bindings/python/dist/
/bindings/python/build/
/bindings/python/*.egg-info/
/bindings/python/.pytest_cache/

# JavaScript
node_modules/

# Rust
/bindings/rust/target/

# Swift
/bindings/swift/.build/
/bindings/swift/Package.resolved

# Go
/bindings/go/go.sum

# Dart
/bindings/dart/.dart_tool/
/bindings/dart/pubspec.lock

# C# / .NET
/bindings/**/obj/
/bindings/**/bin/Debug/
/bindings/**/bin/Release/
*.nupkg
*.snupkg

# Java (Maven)
/bindings/java/out/
/bindings/java/target/
/bindings/kotlin/*.jar

# Kotlin / Native
/bindings/kotlin/build/
/bindings/kotlin/.gradle/

# Haskell
/bindings/haskell/dist-newstyle/
/bindings/haskell/.stack-work/

# Perl (ExtUtils::MakeMaker build outputs)
/bindings/perl/Makefile
/bindings/perl/MYMETA.*
/bindings/perl/MANIFEST
/bindings/perl/blib/
/bindings/perl/pm_to_blib
/bindings/perl/*.tar.gz

# Elixir
/bindings/elixir/_build/
/bindings/elixir/deps/
/bindings/elixir/*.tar

# Ruby
/bindings/ruby/*.gem

# Zig
/.zig-cache/
/zig-out/
/bindings/zig/.zig-cache/
/bindings/zig/zig-out/

# Generic per-binding build dir catch-all
/.build/
/bindings/**/.build/
